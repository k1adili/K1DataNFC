<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Backup section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾  پشتیبان‌گیری"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_backup_local"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📱  ذخیره روی حافظه گوشی (ZIP)"
                android:layout_marginBottom="10dp"
                style="@style/PrimaryButton" />

            <Button
                android:id="@+id/btn_backup_drive"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="☁️  Google Drive"
                android:layout_marginBottom="10dp"
                style="@style/SecondaryButton" />

            <Button
                android:id="@+id/btn_backup_dropbox"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📦  Dropbox"
                android:layout_marginBottom="20dp"
                style="@style/SecondaryButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="16dp" />

            <!-- Restore section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄  بازیابی"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_restore_local"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📂  انتخاب فایل ZIP برای بازیابی"
                android:layout_marginBottom="16dp"
                style="@style/SecondaryButton" />

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginTop="8dp">
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="وضعیت: آماده"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </androidx.cardview.widget.CardView>

            <!-- Info box -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardElevation="1dp"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="⚠️ تمام فایل‌های پشتیبان رمزگذاری شده هستند و بدون این اپ قابل خواندن نیستند."
                    android:textSize="13sp"
                    android:textColor="#2E7D32" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
